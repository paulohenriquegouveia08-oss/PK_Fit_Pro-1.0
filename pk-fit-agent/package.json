{
    "name": "pk-fit-agent",
    "version": "1.0.0",
    "description": "PK Fit Pro Agent — Ponte entre Supabase e catracas de academia",
    "main": "dist/index.js",
    "bin": "dist/index.js",
    "scripts": {
        "dev": "ts-node src/index.ts",
        "build": "tsc",
        "build:exe": "tsc && npx pkg . --output PK-Fit-Agent.exe",
        "start": "node dist/index.js"
    },
    "pkg": {
        "targets": [
            "node18-win-x64"
        ],
        "outputPath": "release",
        "assets": []
    },
    "dependencies": {
        "@supabase/supabase-js": "^2.39.0",
        "dotenv": "^16.3.1"
    },
    "devDependencies": {
        "@types/node": "^20.10.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.3.2"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}